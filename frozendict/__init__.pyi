    def __reversed__(self) -> Iterator[_K]: ...
    def __eq__(self, other: Any) -> bool: ...
    def __le__(self, other: Any) -> bool: ...
    def clear(self) -> None: ...
    def items(self) -> ItemsView[_K, _T]: ...
    def keys(self) -> KeysView[_K]: ...
    def values(self) -> ValuesView[_T]: ...
