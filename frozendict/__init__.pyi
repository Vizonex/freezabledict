    def update(__map: Mapping[_K, _T], **kwargs: _T) -> None: ...
    @overload
    def update(__map: Iterable[tuple[_K, _T]], **kwargs: _T) -> None: ...
    def update(**kwargs: _T) -> None: ...

PyFrozenDict = FrozenDict
