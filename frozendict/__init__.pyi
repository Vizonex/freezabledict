        self: dict[str, _T],  # pyright: ignore[reportInvalidTypeVarUse]  #11780
        map: Mapping[str, _T],
        /,
        **kwargs: _T,
    ) -> None: ...
    def __init__(self, *args: Any, **kwargs: Any) -> None: ...
